# Hyper-DERP Benchmark Environment Variables
#
# Copy to .env and fill in values before running benchmark
# scripts. Source with: set -a; source .env; set +a
#
# Scripts use ${VAR:?} for required variables — they will
# abort with an error if unset.

# ---- Remote relay (GCP/cloud benchmarks) --------------------

# Relay VM internal IP (e.g. 10.x.x.x).
RELAY=
# SSH hostname or IP for relay management.
RELAY_SSH=
# SSH user on relay VM (default: worker).
RELAY_USER=worker
# SSH private key for relay access.
RELAY_KEY=

# ---- Orchestrator scripts (run from workstation) ------------

# GCP VM external IPs (for run_full_sweep.sh).
CLIENT_IP=
RELAY_IP=
# SSH key and user for orchestrator scripts.
SSH_KEY=
SSH_USER=worker

# ---- AWS Phase B (phase_b_aws.sh) --------------------------

REGION=eu-central-1
SUBNET=
SG=
KEY_NAME=hd-bench-key
AMI=
PLACEMENT_GROUP=hd-bench
RELAY_INTERNAL_IP=
CLIENT_INTERNAL_IP=

# ---- Tunnel tests -------------------------------------------

# Relay and client internal IPs.
RELAY_INT=
CLIENT_INT=
# Relay Tailscale IP.
RELAY_TS=
# Headscale pre-auth key.
HS_KEY=
# Tailscale auth key (phase 0 only).
TS_AUTHKEY=

# Tunnel pair IPs (phases 2-4).
PAIR1_SENDER_INT=
PAIR1_RECV_TS=
PAIR1_RECV_INT=
PAIR2_SENDER_INT=
PAIR2_RECV_TS=
PAIR2_RECV_INT=
# Phase 3-4 third pair.
P3_SEND_INT=
P3_RECV_TS=
P3_RECV_INT=

# ---- Local bare-metal tests --------------------------------

# Path to Go derper binary (for comparison benchmarks).
DERPER=
# NetBird auth secret (for scale comparison).
NB_AUTH_SECRET=
